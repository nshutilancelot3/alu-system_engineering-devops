#!/usr/bin/env bash
# Exit immediately if a command fails
set -e

# Update package list and install nginx
apt-get update -y
apt-get install -y nginx

# Create a default index page
echo "Hello World!" > /var/www/html/index.html

# Path to nginx default site config
NGINX_DEFAULT_CONF="/etc/nginx/sites-available/default"

# Check if the redirect already exists to avoid duplicates
if ! grep -q "location /redirect_me" "$NGINX_DEFAULT_CONF"; then
    # Safely insert the redirect inside the server block after server_name line
    sed -i '/server_name _;/a \
    \n    location /redirect_me {\n        return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n    }' "$NGINX_DEFAULT_CONF"
fi

# Test nginx configuration for syntax errors
nginx -t

# Restart nginx to apply changes
service nginx restart