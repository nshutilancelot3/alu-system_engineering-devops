#!/usr/bin/env bash
# Fix Nginx to run as nginx user on port 8080

# Change the listening port from 80 to 8080
sed -i 's/listen 80/listen 8080/' /etc/nginx/sites-enabled/default
sed -i 's/listen \[::\]:80/listen \[::\]:8080/' /etc/nginx/sites-enabled/default

# Set nginx to run as nginx user
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf

# Fix permissions so nginx user can access required files
chown -R nginx /var/log/nginx
chown -R nginx /var/lib/nginx

# Kill any running nginx and restart as nginx user
pkill nginx
nginx